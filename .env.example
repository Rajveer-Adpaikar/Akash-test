# Web3Forms Access Key
# Get yours at https://web3forms.com/
# Without this, the contact form falls back to mailto:
VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Google Sheets Web App URL (from Apps Script deployment)
# Paste the URL from Deploy → New deployment → Web app in your Google Apps Script
VITE_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
